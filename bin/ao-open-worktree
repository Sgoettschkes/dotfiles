#!/usr/bin/env bash
set -euo pipefail

WORKTREE_PATH="${1:-}"
INSTRUCTION="${2:-}"

if [ -z "$WORKTREE_PATH" ]; then
  echo "Usage: ao-open-worktree /path/to/worktree [initial instruction]"
  echo "The instruction may be multi-line, e.g. \"\$(cat prompt.txt)\"."
  exit 1
fi

if [ ! -d "$WORKTREE_PATH" ]; then
  echo "Directory does not exist: $WORKTREE_PATH"
  exit 1
fi

# Resolve to an absolute path so cd works regardless of the caller's cwd.
WORKTREE_PATH="$(cd "$WORKTREE_PATH" && pwd)"

# Shell-quote the path so it is safe to type into the iTerm shell, and pass it
# via osascript argv rather than interpolating it into the AppleScript source.
# This prevents both AppleScript string injection and shell command injection
# from a path containing quotes, backticks, or command substitution.
QUOTED_PATH="$(printf '%q' "$WORKTREE_PATH")"

# Assemble the command typed into the claude session. printf '%q' also collapses
# any newlines in a multi-line instruction into $'...\n...' form, so it is typed
# as a single safe line while claude still receives the original multi-line text.
CLAUDE_CMD="cd $QUOTED_PATH && claude --permission-mode auto"
if [ -n "$INSTRUCTION" ]; then
  CLAUDE_CMD="$CLAUDE_CMD $(printf '%q' "$INSTRUCTION")"
fi

osascript - "$QUOTED_PATH" "$CLAUDE_CMD" <<'EOF'
on run argv
  set qpath to item 1 of argv
  set claudeCmd to item 2 of argv

  tell application "iTerm2"
    activate

    if (count of windows) = 0 then
      create window with default profile
    end if

    tell current window
      create tab with default profile

      tell current session of current tab
        write text "cd " & qpath
        split vertically with default profile
      end tell

      delay 0.2

      tell first session of current tab
        write text claudeCmd
      end tell

      tell second session of current tab
        write text "cd " & qpath
        write text "cl"
      end tell
    end tell
  end tell
end run
EOF
