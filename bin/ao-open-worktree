#!/usr/bin/env bash
set -euo pipefail

WORKTREE_PATH="${1:-}"
INSTRUCTION="${2:-}"

if [ -z "$WORKTREE_PATH" ]; then
  echo "Usage: ao-open-worktree /path/to/worktree [initial instruction]"
  echo "Keep the instruction short — put long context in a file inside the worktree and pass a pointer to it."
  echo "With no instruction the panes are opened (cd'd into the worktree) without launching claude."
  exit 1
fi

if [ ! -d "$WORKTREE_PATH" ]; then
  echo "Directory does not exist: $WORKTREE_PATH"
  exit 1
fi

# Resolve to an absolute path so cd works regardless of the caller's cwd.
WORKTREE_PATH="$(cd "$WORKTREE_PATH" && pwd)"

# Shell-quote the path so it is safe to type into the iTerm shell, and pass it
# via osascript argv rather than interpolating it into the AppleScript source.
# This prevents both AppleScript string injection and shell command injection
# from a path containing quotes, backticks, or command substitution.
QUOTED_PATH="$(printf '%q' "$WORKTREE_PATH")"

# Left-pane command. The instruction is typed inline into the pane; iTerm's
# write text corrupts very long literals mid-stream, so callers keep prompts
# short and put long context in a file inside the worktree (see usage).
# Without an instruction we just cd in (handy for testing the pane layout).
if [ -n "$INSTRUCTION" ]; then
  QUOTED_INSTRUCTION="$(printf '%q' "$INSTRUCTION")"
  LEFT_CMD="cd $QUOTED_PATH && claude --permission-mode auto $QUOTED_INSTRUCTION"
else
  LEFT_CMD="cd $QUOTED_PATH"
fi

osascript - "$QUOTED_PATH" "$LEFT_CMD" <<'EOF'
on run argv
  set qpath to item 1 of argv
  set leftCmd to item 2 of argv

  tell application "iTerm2"
    activate

    if (count of windows) = 0 then
      create window with default profile
    end if

    tell current window
      create tab with default profile

      tell current tab
        -- Capture explicit session handles. "first/second session" is
        -- unreliable right after a split, which let writes land in the wrong
        -- pane (or interleave) before.
        set leftSession to current session
        delay 0.4

        tell leftSession
          set rightSession to (split vertically with default profile)
        end tell
        delay 0.6

        -- Right pane first (short writes), so it finishes before the left
        -- pane's command is typed and nothing races into the left pane.
        tell rightSession
          write text "cd " & qpath
          delay 0.4
          write text "cl"
        end tell
        delay 0.5

        -- Left pane last. Nothing is written after it, so even a longer
        -- command can't be corrupted by a competing write.
        tell leftSession
          write text leftCmd
        end tell

        -- Land focus on the claude pane, not the spare shell created by split.
        select leftSession
      end tell
    end tell
  end tell
end run
EOF

if [ -n "$INSTRUCTION" ]; then
  echo "Launched claude in $WORKTREE_PATH"
else
  echo "Opened panes in $WORKTREE_PATH (no instruction → claude not launched)"
fi
